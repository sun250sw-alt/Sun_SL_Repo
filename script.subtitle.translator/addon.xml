<?xml version="1.0" encoding="UTF-8"?>
<addon id="script.subtitle.translator"
       name="Subtitle Translator"
       version="1.3.0"
       provider-name="SubTranslator">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <!-- Main script — runnable from Add-ons menu -->
  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>

  <!-- Context menu — appears when pressing Menu/C during playback -->
  <extension point="xbmc.python.contextmenu" library="contextmenu.py">
    <menu id="kodi.core.videos"/>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Subtitle Translator</summary>
    <description lang="en_GB">
      Translate subtitles using Google Translate. Access from the
      right-click context menu during video playback, or press T on
      keyboard. Browse SRT or ZIP files. Supports 100+ languages.
    </description>
    <platform>all</platform>
    <license>GPL-2.0-only</license>
  </extension>

</addon>

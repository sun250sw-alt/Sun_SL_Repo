<?xml version="1.0" encoding="UTF-8"?>
<!--
  Press T during video playback to open Subtitle Translator.
  Also works with the Subtitle button on remotes.
-->
<keymap>
  <FullscreenVideo>
    <keyboard>
      <t>RunScript(script.subtitle.translator)</t>
    </keyboard>
    <remote>
      <subtitle>RunScript(script.subtitle.translator)</subtitle>
      <blue>RunScript(script.subtitle.translator)</blue>
    </remote>
  </FullscreenVideo>
  <VideoMenu>
    <keyboard>
      <t>RunScript(script.subtitle.translator)</t>
    </keyboard>
  </VideoMenu>
</keymap>

<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="2">
  <section id="general">
    <category id="general" label="Translation Settings">

      <group id="1" label="Gemini AI — Optional (more accurate than Google Translate)">

        <setting id="gemini_api_key" type="string" label="Gemini API Key">
          <default></default>
        </setting>

        <setting id="gemini_model" type="string" label="Gemini Model">
          <default>gemini-2.5-flash</default>
          <constraints>
            <option label="Gemini 2.5 Flash — Best quality | 250 req/day | ~10 movies/day">gemini-2.5-flash</option>
            <option label="Gemini 2.5 Flash-Lite — Good quality | 1000 req/day | ~43 movies/day">gemini-2.5-flash-lite</option>
            <option label="Gemini 2.5 Pro — Highest quality | 100 req/day | ~4 movies/day">gemini-2.5-pro</option>
          </constraints>
        </setting>

        <setting id="gemini_note1" type="string" label="--- Free tier limits reset daily at midnight Pacific Time">
          <default></default>
        </setting>
        <setting id="gemini_note2" type="string" label="--- Get a free API key at: aistudio.google.com">
          <default></default>
        </setting>
        <setting id="gemini_note3" type="string" label="--- If limit reached, falls back to Google Translate automatically">
          <default></default>
        </setting>

      </group>

      <group id="2" label="General">
        <setting id="target_language" type="string" label="Last used language (auto-saved)">
          <default>en</default>
        </setting>
      </group>

    </category>
  </section>
</settings>
